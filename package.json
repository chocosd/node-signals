{
  "name": "tiny-signals-core",
  "version": "1.0.0",
  "description": "A tiny reactive signals implementation with type-safe transform pipelines",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run typecheck && npm run build"
  },
  "keywords": [
    "signals",
    "reactive",
    "reactivity",
    "effect",
    "computed",
    "pipeline"
  ],
  "license": "ISC",
  "sideEffects": false,
  "devDependencies": {
    "tsup": "8.5.1",
    "typescript": "6.0.3",
    "vite": "^6.3.5"
  }
}
